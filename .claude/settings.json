{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout -b *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "SKILL_EVAL_THRESHOLD": "80"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-prd-check.sh",
            "timeout": 10,
            "statusMessage": "Checking PRD skill health before execution"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/log-prd-result.sh",
            "timeout": 10,
            "statusMessage": "Logging PRD generation result"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prd-quality-check.sh",
            "timeout": 15,
            "statusMessage": "Validating PRD structure and quality"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-prd-eval.sh",
            "timeout": 30,
            "statusMessage": "Evaluating PRD quality and updating metrics"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-report.sh",
            "timeout": 15,
            "statusMessage": "Generating session PRD quality report"
          }
        ]
      }
    ]
  }
}
